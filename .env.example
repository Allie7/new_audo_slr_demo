# 系统 LLM (GLM)
OPENAI_API_KEY=your-zhipuai-api-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-5.1

# 模拟学生 LLM (DeepSeek)
SIMULATOR_API_KEY=your-deepseek-api-key-here
SIMULATOR_BASE_URL=https://api.deepseek.com/
SIMULATOR_MODEL=deepseek-chat

# 代理配置（可选，用于访问 Semantic Scholar / arXiv 等海外 API）
# 示例: http://127.0.0.1:7890 或 socks5://127.0.0.1:1080
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
